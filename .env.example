# Slack Bot Token (xoxb-로 시작)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (xapp-로 시작, Socket Mode용)
SLACK_APP_TOKEN=xapp-your-app-token-here

# 피드백을 전달받을 채널 ID (선택사항 - 설정 시 해당 채널로 피드백 요약 전송)
# FEEDBACK_CHANNEL_ID=C01234ABCDE

# Anthropic API Key (/피드백 커맨드의 배너 분석 기능에 필요)
# https://console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Figma Access Token (/피드백 커맨드의 피그마 이미지 가져오기에 필요)
# Figma → Settings → Security → Personal access tokens 에서 발급
FIGMA_ACCESS_TOKEN=figd_your-figma-token-here
